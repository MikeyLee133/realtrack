# Supabase backend (optional).
#
# Leave these UNSET to run on the localStorage backend (the default — no
# account, no network). Set BOTH to switch the app to Supabase: login required,
# per-user isolation via Row-Level Security, and private file storage.
#
# Copy this file to `.env` and fill in the values from your Supabase project
# (Project Settings → API). See docs/SUPABASE.md for the full setup.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
